# TinyClaw Environment Configuration
# Copy this file to .env and fill in your values

# API Configuration
ANTHROPIC_API_KEY=your-api-key-here

# Gateway Configuration
GATEWAY_BIND=127.0.0.1:18789
GATEWAY_VERBOSE=false

# Data Directory
DATA_DIR=~/.local/share/tiny_claw
LOG_DIR=~/.local/share/tiny_claw/logs
CONFIG_DIR=~/.config/tiny_claw

# Log Level (trace, debug, info, warn, error)
RUST_LOG=info
